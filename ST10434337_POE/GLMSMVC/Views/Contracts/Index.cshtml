@model GLMSMVC.Models.ViewModels.ContractIndexViewModel

@{
    ViewData["Title"] = "Contracts";
}

<h1>Contracts</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<form asp-action="Index" method="get" class="row g-3 mb-4">
    <div class="col-md-3">
        <label asp-for="StartDate" class="form-label">Start Date</label>
        <input asp-for="StartDate" class="form-control" type="date" />
    </div>

    <div class="col-md-3">
        <label asp-for="EndDate" class="form-label">End Date</label>
        <input asp-for="EndDate" class="form-control" type="date" />
    </div>

    <div class="col-md-3">
        <label asp-for="Status" class="form-label">Status</label>
        <select asp-for="Status" asp-items="Model.StatusOptions" class="form-select"></select>
    </div>

    <div class="col-md-3 d-flex align-items-end gap-2">
        <button type="submit" class="btn btn-primary">Filter / Search</button>
        <a asp-action="Create" class="btn btn-success">Create Contract</a>
    </div>
</form>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Client Name</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Service Level</th>
            <th>Contract Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.ClientName</td>
                <td>@item.StartDate?.ToString("yyyy-MM-dd")</td>
                <td>@item.EndDate?.ToString("yyyy-MM-dd")</td>
                <td>@item.ServiceLevel</td>
                <td>@item.ContractStatus</td>
                <td>
                    @if (item.CanEdit)
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    }
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>