@model GLMSMVC.Models.ViewModels.ContractFormViewModel

@{
    ViewData["Title"] = "Edit Contract";
}

<h1>Edit Contract</h1>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input asp-for="Id" type="hidden" />

    <div class="mb-3">
        <label asp-for="ClientId" class="form-label"></label>
        <select asp-for="ClientId" asp-items="Model.ClientOptions" class="form-select">
            <option value="">-- Select Client --</option>
        </select>
        <span asp-validation-for="ClientId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="StartDate" class="form-label"></label>
        <input asp-for="StartDate" class="form-control" type="date" />
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EndDate" class="form-label"></label>
        <input asp-for="EndDate" class="form-control" type="date" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ServiceLevel" class="form-label"></label>
        <select asp-for="ServiceLevel" asp-items="Model.ServiceLevelOptions" class="form-select">
            <option value="">-- Select Service Level --</option>
        </select>
        <span asp-validation-for="ServiceLevel" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="PauseContract" class="form-check-input" />
        <label asp-for="PauseContract" class="form-check-label"></label>
    </div>

    <div class="mb-3">
        <label asp-for="File" class="form-label"></label>
        <input asp-for="File" class="form-control" type="file" accept=".pdf,application/pdf" />
        <span asp-validation-for="File" class="text-danger"></span>
        <div class="form-text">Upload a new PDF to replace the current file.</div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ExistingFilePath))
    {
        <div class="mb-3">
            <span class="badge bg-secondary">Current file exists</span>
        </div>
    }

    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}