@model GLMSMVC.Models.ViewModels.ContractFormViewModel

@{
    ViewData["Title"] = "Create Contract";
}

<h1>Create Contract</h1>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="mb-3">
        <label asp-for="ClientId" class="form-label"></label>
        <select asp-for="ClientId" asp-items="Model.ClientOptions" class="form-select">
            <option value="">-- Select Client --</option>
        </select>
        <span asp-validation-for="ClientId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="StartDate" class="form-label"></label>
        <input asp-for="StartDate" class="form-control" type="date" />
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EndDate" class="form-label"></label>
        <input asp-for="EndDate" class="form-control" type="date" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ServiceLevel" class="form-label"></label>
        <select asp-for="ServiceLevel" asp-items="Model.ServiceLevelOptions" class="form-select">
            <option value="">-- Select Service Level --</option>
        </select>
        <span asp-validation-for="ServiceLevel" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="File" class="form-label"></label>
        <input asp-for="File" class="form-control" type="file" accept=".pdf,application/pdf" />
        <span asp-validation-for="File" class="text-danger"></span>
        <div class="form-text">PDF only.</div>
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}