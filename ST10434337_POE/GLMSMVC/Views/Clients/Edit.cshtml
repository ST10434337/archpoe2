@model GLMSMVC.Models.ViewModels.ClientFormViewModel

@{
    ViewData["Title"] = "Edit Client";
}

<h1>Edit Client</h1>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<form asp-action="Edit" method="post">
    <input asp-for="Id" type="hidden" />

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ContactDetails" class="form-label"></label>
        <input asp-for="ContactDetails" class="form-control" />
        <span asp-validation-for="ContactDetails" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Region" class="form-label"></label>
        <select asp-for="Region" asp-items="Model.RegionOptions" class="form-select">
            <option value="">-- Select Country --</option>
        </select>
        <span asp-validation-for="Region" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}