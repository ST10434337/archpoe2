@model GLMSMVC.Models.ViewModels.ServiceRequestDetailsViewModel

@{
    ViewData["Title"] = "Service Request Details";
}

<h1>Service Request Details</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<dl class="row">
    <dt class="col-sm-3">Client Name</dt>
    <dd class="col-sm-9">@Model.ClientName</dd>

    <dt class="col-sm-3">Contract Id</dt>
    <dd class="col-sm-9">@Model.ContractId</dd>

    <dt class="col-sm-3">Start Date</dt>
    <dd class="col-sm-9">@Model.StartDate?.ToString("yyyy-MM-dd")</dd>

    <dt class="col-sm-3">End Date</dt>
    <dd class="col-sm-9">@Model.EndDate?.ToString("yyyy-MM-dd")</dd>

    <dt class="col-sm-3">Service Level</dt>
    <dd class="col-sm-9">@Model.ServiceLevel</dd>

    <dt class="col-sm-3">SR Status</dt>
    <dd class="col-sm-9">@Model.ServiceRequestStatus</dd>

    <dt class="col-sm-3">Contract File</dt>
    <dd class="col-sm-9">
        @if (Model.CanDownloadFile)
        {
            <a asp-action="DownloadContractFile" asp-route-id="@Model.Id" class="btn btn-sm btn-success">Download File</a>
        }
        else
        {
            <span>No contract file available.</span>
        }
    </dd>
</dl>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>