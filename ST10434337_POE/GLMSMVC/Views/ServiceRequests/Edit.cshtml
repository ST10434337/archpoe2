@model GLMSMVC.Models.ViewModels.ServiceRequestEditViewModel

@{
    ViewData["Title"] = "Edit Service Request";
}

<h1>Edit Service Request</h1>

@if (!string.IsNullOrWhiteSpace(Model.ApiError))
{
    <div class="alert alert-warning">
        <strong>Currency API issue:</strong> @Model.ApiError
    </div>
}

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<form asp-action="Edit" method="post">
    <input asp-for="Id" type="hidden" />
    <input asp-for="ContractId" type="hidden" />

    <div class="mb-3">
        <label class="form-label">Client Name</label>
        <input class="form-control" value="@Model.ClientName" readonly />
    </div>

    <div class="mb-3">
        <label class="form-label">Contract Status</label>
        <input class="form-control" value="@Model.ContractStatus" readonly />
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        @if (Model.IsReadOnly)
        {
            <textarea asp-for="Description" class="form-control" rows="4" readonly></textarea>
        }
        else
        {
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        }
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="OriginalAmount" class="form-label"></label>
        @if (Model.IsReadOnly)
        {
            <input asp-for="OriginalAmount" class="form-control" readonly />
        }
        else
        {
            <input asp-for="OriginalAmount" class="form-control" />
        }
        <span asp-validation-for="OriginalAmount" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CurrencyCode" class="form-label"></label>
        @if (Model.IsReadOnly)
        {
            <select asp-for="CurrencyCode" asp-items="Model.CurrencyOptions" class="form-select" disabled></select>
            <input type="hidden" asp-for="CurrencyCode" />
        }
        else
        {
            <select asp-for="CurrencyCode" asp-items="Model.CurrencyOptions" class="form-select"></select>
        }
        <span asp-validation-for="CurrencyCode" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Status" class="form-label"></label>
        @if (Model.IsReadOnly)
        {
            <select asp-for="Status" asp-items="Model.StatusOptions" class="form-select" disabled></select>
            <input type="hidden" asp-for="Status" />
        }
        else
        {
            <select asp-for="Status" asp-items="Model.StatusOptions" class="form-select"></select>
        }
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        @if (Model.IsReadOnly)
        {
            <input asp-for="UseApi" class="form-check-input" disabled />
            <input type="hidden" asp-for="UseApi" />
        }
        else
        {
            <input asp-for="UseApi" class="form-check-input" />
        }
        <label asp-for="UseApi" class="form-check-label"></label>
    </div>

    <div class="mb-3">
        <label asp-for="CostZar" class="form-label"></label>
        <input asp-for="CostZar" class="form-control" readonly />
    </div>

    @if (!Model.IsReadOnly)
    {
        <button type="submit" class="btn btn-primary">Save Changes</button>
    }

    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}